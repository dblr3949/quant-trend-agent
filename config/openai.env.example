# Local OpenAI settings for the position-agent web app.
# Copy this file to config/openai.env and put your real key there.
# Never commit the real config/openai.env file.

# Cloud deployment settings. For the current web login UI, prefer APP_AUTH_MODE=users.
# APP_PASSWORD is the legacy Basic Auth fallback and is ignored when user mode is on.
HOST=127.0.0.1
PORT=8765
APP_USERNAME=agent
APP_PASSWORD=REPLACE_WITH_PRIVATE_WEB_PASSWORD
APP_DATA_DIR=
APP_AUTH_MODE=users
# Comma separated seed users. Format:
# username:password:display_name:admin
# The seed password is re-applied on startup, so change it here and redeploy to reset.
APP_SEED_USERS=agent:REPLACE_WITH_WEB_PASSWORD:Agent:admin

OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=qwen3.7-max
OPENAI_DECISION_REASONING_EFFORT=medium
OPENAI_DECISION_MAX_OUTPUT_TOKENS=12000
OPENAI_SUMMARY_REASONING_EFFORT=medium
OPENAI_SUMMARY_MAX_OUTPUT_TOKENS=8000
OPENAI_RETRY_429_SECONDS=20,60
OPENAI_DECISION_VERBOSITY=low
OPENAI_SUMMARY_VERBOSITY=medium

# Optional: DeepSeek (OpenAI-compatible). Only needed if you pick a deepseek-* model
# in the web UI dropdown. Get a key at platform.deepseek.com.
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: Qwen via Alibaba Cloud Model Studio / 百炼 (OpenAI-compatible). Needed
# if you pick a qwen* model. The account must activate the model first. Default
# base URL is the China (Beijing) endpoint; override for other regions.
DASHSCOPE_API_KEY=REPLACE_WITH_DASHSCOPE_API_KEY
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Massive / Polygon proxy market data. Keep the real key only in config/openai.env.
MASSIVE_API_KEY=REPLACE_WITH_MASSIVE_PROXY_KEY
MASSIVE_REST_URL=http://44.219.45.87:8081
MASSIVE_WS_URL=ws://44.219.45.87:8080/ws
